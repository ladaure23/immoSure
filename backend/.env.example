# ─── Application ───────────────────────────────────────────────
APP_URL=https://immosure.bj
ENVIRONMENT=development
SECRET_KEY=changeme-use-openssl-rand-hex-32-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── Database ──────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://immosure:password@localhost:5432/immosure

# ─── FedaPay ───────────────────────────────────────────────────
FEDAPAY_SECRET_KEY=sk_sandbox_xxxxxxxxxxxxxxxxxxxx
FEDAPAY_PUBLIC_KEY=pk_sandbox_xxxxxxxxxxxxxxxxxxxx
FEDAPAY_WEBHOOK_SECRET=webhook_secret_xxxxxxxxxxxx
FEDAPAY_ENV=sandbox

# ─── KKiaPay ───────────────────────────────────────────────────
KKIAPAY_PRIVATE_KEY=kkiapay_private_xxxxxxxxxxxx
KKIAPAY_PUBLIC_KEY=kkiapay_public_xxxxxxxxxxxx
KKIAPAY_SECRET=kkiapay_secret_xxxxxxxxxxxx
KKIAPAY_SANDBOX=true

# ─── Telegram ──────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# ─── Anthropic ─────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# ─── Upload Storage ────────────────────────────────────────────
UPLOAD_DIR=/uploads/receipts

# ─── Scheduler ─────────────────────────────────────────────────
SCHEDULER_TIMEZONE=Africa/Porto-Novo
NOTIFICATION_HOUR=9
NOTIFICATION_MINUTE=0
